import { useState } from "react";

export default function Toggle() {
  const [status, setStatus] = useState(false);

  function handleClick() {
    setStatus(true);
  }

  return (
    <div>
      <p>
        {status ? "Activated" : "Not Activated"}
      </p>

      <button onClick={handleClick}>
        Activate
      </button>
    </div>
  );
}

